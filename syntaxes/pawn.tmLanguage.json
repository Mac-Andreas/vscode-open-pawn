{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pawn",
  "scopeName": "source.pawn",
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#tags" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-definition" },
    { "include": "#function-call" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.pawn",
          "match": "///.*$"
        },
        { "name": "comment.line.double-slash.pawn", "match": "//.*$" },
        {
          "name": "comment.block.documentation.pawn",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "keyword.other.documentation.pawn",
              "match": "@(param|return|remarks|note|brief|code|endcode|see)\\b"
            }
          ]
        },
        {
          "name": "comment.block.pawn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.pawn",
          "match": "^\\s*(#)\\s*(include|tryinclude)\\s+([<\"][^>\"]*[>\"])?",
          "captures": {
            "1": { "name": "punctuation.definition.directive.pawn" },
            "2": { "name": "keyword.control.directive.include.pawn" },
            "3": { "name": "string.quoted.other.include.pawn" }
          }
        },
        {
          "name": "meta.preprocessor.pawn",
          "match": "^\\s*(#)\\s*(define|undef|if|ifdef|ifndef|else|elseif|endif|endinput|error|warning|pragma|assert|emit|file|line|section)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.pawn" },
            "2": { "name": "keyword.control.directive.pawn" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.pawn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.pawn",
          "match": "\\\\(x[0-9A-Fa-f]+|[0-9]+|[abefnrtv\\\\'\"%]|.)"
        },
        {
          "name": "constant.other.placeholder.pawn",
          "match": "%[-+ 0]*[0-9*]*(\\.[0-9*]+)?[diouxXeEfgGcsbn%]"
        }
      ]
    },
    "characters": {
      "name": "string.quoted.single.pawn",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.pawn",
          "match": "\\\\(x[0-9A-Fa-f]+|[0-9]+|[abefnrtv\\\\'\"%]|.)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pawn",
          "match": "\\b(if|else|while|do|for|switch|case|default|break|continue|return|goto|assert|exit|sleep)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.modifier.pawn",
          "match": "\\b(new|const|static|stock|public|forward|native|enum|operator|state|const_arg|decl)\\b"
        },
        {
          "name": "storage.type.pawn",
          "match": "\\b(Float|bool|Text|File|DBResult|DB|Menu|Text3D|PlayerText3D|PlayerText|GlobalString|StringTag)(?=\\s*:)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pawn",
          "match": "\\b(true|false|null|cellbits|cellmax|cellmin|charbits|charmax|charmin|ucharmax|EOS|__Pawn|__line|debug)\\b"
        },
        {
          "name": "support.constant.samp.pawn",
          "match": "\\b(INVALID_PLAYER_ID|INVALID_VEHICLE_ID|INVALID_OBJECT_ID|INVALID_PLAYER_OBJECT_ID|INVALID_TEXT_DRAW|INVALID_MENU|INVALID_ACTOR_ID|INVALID_3DTEXT_ID|MAX_PLAYERS|MAX_VEHICLES|MAX_OBJECTS|MAX_PLAYER_NAME|MAX_ACTORS|PLAYER_STATE_\\w+|WEAPON_\\w+|DIALOG_STYLE_\\w+|PLAYER_VARTYPE_\\w+|SPECTATE_MODE_\\w+|CAMERA_CUT|CAMERA_MOVE)\\b"
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "name": "entity.name.type.tag.pawn",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(:)(?!:)",
          "captures": {
            "1": { "name": "entity.name.type.tag.pawn" },
            "2": { "name": "punctuation.separator.tag.pawn" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.pawn", "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.binary.pawn", "match": "\\b0[bB][01_]+\\b" },
        { "name": "constant.numeric.float.pawn", "match": "\\b[0-9][0-9_]*\\.[0-9_]+([eE][-+]?[0-9]+)?\\b" },
        { "name": "constant.numeric.decimal.pawn", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.pawn", "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|>>=|<<=|=)" },
        { "name": "keyword.operator.comparison.pawn", "match": "(==|!=|<=|>=|<|>)" },
        { "name": "keyword.operator.logical.pawn", "match": "(&&|\\|\\||!)" },
        { "name": "keyword.operator.arithmetic.pawn", "match": "(\\+\\+|--|\\+|-|\\*|/|%|<<|>>|&|\\||\\^|~)" },
        { "name": "keyword.operator.ternary.pawn", "match": "(\\?|:)" }
      ]
    },
    "function-definition": {
      "match": "\\b(public|stock|forward|native)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "storage.modifier.pawn" },
        "2": { "name": "entity.name.function.pawn" }
      }
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.pawn",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.pawn" }
          }
        }
      ]
    }
  }
}
